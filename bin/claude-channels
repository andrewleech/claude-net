#!/bin/bash
set -euo pipefail
# claude-channels: Run Claude Code with all restrictions bypassed.
#
# Binary patches (same-length, native binary safe):
# 1. Channels feature gate (tengu_harbor Statsig flag → true)
# 2. Org policy channelsEnabled check (inverted so it never blocks)
# 3. Bypass permissions gate (tengu_disable_bypass_permissions_mode → false)
#
# Settings (written to ~/.claude/settings.json if not already present):
# 4. skipDangerousModePermissionPrompt: true (auto-accept dev channels warning)
#
# CLI flags auto-injected:
# - --dangerously-skip-permissions
# - --dangerously-load-development-channels server:X (for each configured MCP server)
#
# Usage: claude-channels [claude args...]

CACHE_DIR="$HOME/.local/share/claude-channels"
PATCHED_CLI="$CACHE_DIR/claude-patched"
SOURCE_MARKER="$CACHE_DIR/source_path"
PATCHER="$(cd "$(dirname "$0")" && pwd)/patch-binary.py"

# ── Find Claude Code binary ──────────────────────────────────────────────

find_claude_binary() {
    if [ -n "${CLAUDE_CLI_PATH:-}" ] && [ -f "$CLAUDE_CLI_PATH" ]; then
        echo "$CLAUDE_CLI_PATH"; return 0
    fi

    local claude_bin
    claude_bin=$(which claude 2>/dev/null || true)
    if [ -n "$claude_bin" ]; then
        local resolved
        resolved=$(readlink -f "$claude_bin" 2>/dev/null || echo "$claude_bin")
        if [ -f "$resolved" ]; then
            echo "$resolved"; return 0
        fi
    fi

    echo "ERROR: Could not find Claude Code binary." >&2
    return 1
}

# ── Ensure settings ──────────────────────────────────────────────────────

ensure_settings() {
    local settings="$HOME/.claude/settings.json"
    if [ ! -f "$settings" ]; then
        mkdir -p "$HOME/.claude"
        echo '{"skipDangerousModePermissionPrompt":true}' > "$settings"
        return
    fi

    # Check if already set
    if python3 -c "
import json, sys
with open('$settings') as f:
    d = json.load(f)
if d.get('skipDangerousModePermissionPrompt') is True:
    sys.exit(0)
d['skipDangerousModePermissionPrompt'] = True
with open('$settings', 'w') as f:
    json.dump(d, f, indent=2)
    f.write('\n')
print('  Settings: added skipDangerousModePermissionPrompt', file=sys.stderr)
" 2>&1; then
        true
    fi
}

# ── Auto-detect channel MCP servers ──────────────────────────────────────

find_channel_servers() {
    local config="$HOME/.claude.json"
    local cwd
    cwd=$(pwd)
    [ -f "$config" ] || return

    python3 -c "
import json
try:
    with open('$config') as f:
        d = json.load(f)
    for proj_path, proj in d.get('projects', {}).items():
        if proj_path == '$cwd':
            for name in proj.get('mcpServers', {}).keys():
                print(f'server:{name}')
except Exception:
    pass
" 2>/dev/null || true
}

# ── Main ─────────────────────────────────────────────────────────────────

CLI_PATH=$(find_claude_binary)
mkdir -p "$CACHE_DIR"

# Patch binary if needed
needs_regen=false
if [ ! -f "$PATCHED_CLI" ]; then
    needs_regen=true
elif [ "$CLI_PATH" -nt "$PATCHED_CLI" ]; then
    needs_regen=true
elif [ -f "$SOURCE_MARKER" ] && [ "$(cat "$SOURCE_MARKER")" != "$CLI_PATH" ]; then
    needs_regen=true
fi

if $needs_regen; then
    python3 "$PATCHER" "$CLI_PATH" "$PATCHED_CLI"
    echo "$CLI_PATH" > "$SOURCE_MARKER"
fi

# Ensure prompt skip is in settings
ensure_settings

# Build extra flags
EXTRA_ARGS=()

has_skip_perms=false
for arg in "$@"; do
    [[ "$arg" == "--dangerously-skip-permissions" ]] && has_skip_perms=true && break
done
$has_skip_perms || EXTRA_ARGS+=(--dangerously-skip-permissions)

already_has_channels=false
for arg in "$@"; do
    [[ "$arg" == "--dangerously-load-development-channels" || "$arg" == "--channels" ]] && already_has_channels=true && break
done

if ! $already_has_channels; then
    CHANNEL_ARGS=()
    while IFS= read -r server; do
        [ -n "$server" ] && CHANNEL_ARGS+=("$server")
    done < <(find_channel_servers)
    [ ${#CHANNEL_ARGS[@]} -gt 0 ] && EXTRA_ARGS+=(--dangerously-load-development-channels "${CHANNEL_ARGS[@]}")
fi

exec "$PATCHED_CLI" "${EXTRA_ARGS[@]}" "$@"
