#!/bin/bash
set -euo pipefail
# claude-channels: Run Claude Code with channel restrictions bypassed.
#
# Patches the Claude Code binary to:
# 1. Enable channels feature gate (tengu_harbor Statsig flag)
# 2. Auto-register channels for any MCP server declaring claude/channel capability
#    (no --channels or --dangerously-load-development-channels flag needed)
# 3. Bypass org policy channelsEnabled check
# 4. Enable --dangerously-skip-permissions regardless of org/Statsig gates
#
# Usage:
#   claude-channels [claude args...]
#   claude-channels --dangerously-skip-permissions
#
# The original binary is never modified. A patched copy is cached at
# ~/.local/share/claude-channels/ and regenerated when the source updates.

CACHE_DIR="$HOME/.local/share/claude-channels"
PATCHED_CLI="$CACHE_DIR/claude-patched.js"
SOURCE_MARKER="$CACHE_DIR/source_path"

# ── Find Claude Code binary ──────────────────────────────────────────────

find_claude_binary() {
    # 1. Environment override
    if [ -n "${CLAUDE_CLI_PATH:-}" ] && [ -f "$CLAUDE_CLI_PATH" ]; then
        echo "$CLAUDE_CLI_PATH"
        return 0
    fi

    # 2. Local installer (cli.js)
    local local_path="$HOME/.claude/local/node_modules/@anthropic-ai/claude-code/cli.js"
    if [ -f "$local_path" ]; then
        echo "$local_path"
        return 0
    fi

    # 3. Resolve 'claude' from PATH, follow symlinks
    local claude_bin
    claude_bin=$(which claude 2>/dev/null || true)
    if [ -n "$claude_bin" ]; then
        local resolved
        resolved=$(readlink -f "$claude_bin" 2>/dev/null || echo "$claude_bin")
        if [ -f "$resolved" ]; then
            echo "$resolved"
            return 0
        fi
    fi

    # 4. npm global
    local npm_root
    npm_root=$(npm root -g 2>/dev/null || true)
    if [ -n "$npm_root" ]; then
        local npm_path="$npm_root/@anthropic-ai/claude-code/cli.js"
        if [ -f "$npm_path" ]; then
            echo "$npm_path"
            return 0
        fi
    fi

    echo "ERROR: Could not find Claude Code binary." >&2
    echo "Set CLAUDE_CLI_PATH or ensure 'claude' is on your PATH." >&2
    return 1
}

# ── Patch the JS source ──────────────────────────────────────────────────
#
# The compiled Bun binary can't be byte-patched (internal checksums).
# Instead, install the npm package to get cli.js and patch that with sed
# (same approach as claude-swarm).

apply_patches() {
    local src="$1"
    local dst="$2"

    echo "Patching Claude Code for channels + bypass support..." >&2

    # Get the version from the binary
    local version
    version=$("$src" --version 2>/dev/null | head -1 | sed 's/ .*//')
    if [ -z "$version" ]; then
        echo "ERROR: Could not determine Claude Code version" >&2
        return 1
    fi

    # Install npm package to get patchable JS
    local npm_dir="$CACHE_DIR/npm"
    local cli_js="$npm_dir/node_modules/@anthropic-ai/claude-code/cli.js"

    if [ ! -f "$cli_js" ] || [ "$src" -nt "$cli_js" ]; then
        echo "  Installing @anthropic-ai/claude-code@${version} for JS patching..." >&2
        mkdir -p "$npm_dir"
        (cd "$npm_dir" && npm install --no-save "@anthropic-ai/claude-code@${version}" 2>&1 | tail -1) >&2
    fi

    if [ ! -f "$cli_js" ]; then
        echo "ERROR: Failed to install npm package" >&2
        return 1
    fi

    cp "$cli_js" "$dst"
    local orig_size
    orig_size=$(stat -c%s "$dst")

    # ── Patch 1: Feature gate bypass (tengu_harbor → always true) ────
    local gate_pattern='function [a-zA-Z0-9_$]\+(){return [a-zA-Z0-9_$]\+("tengu_harbor",!1)}'
    local gate_count
    gate_count=$(grep -cP '\{return [a-zA-Z0-9_$]+\("tengu_harbor",!1\)\}' "$dst" || true)

    if [ "$gate_count" -eq 0 ]; then
        echo "  Patch 1: Feature gate — pattern not found" >&2
    else
        echo "  Patch 1: Feature gate (tengu_harbor) — $gate_count match(es)" >&2
        sed -i -E 's/\{return ([a-zA-Z0-9_$]+)\("tengu_harbor",!1\)\}/\{return!0;return \1("tengu_harbor",!1)\}/g' "$dst"
    fi

    # ── Patch 2: Channel registration gate bypass ────────────────────
    local reg_count
    reg_count=$(grep -cP 'capability"\};if\(![a-zA-Z0-9_$]+\(\)\)return\{action:"skip",kind:"disabled"' "$dst" || true)

    if [ "$reg_count" -eq 0 ]; then
        echo "  Patch 2: Channel registration gate — pattern not found" >&2
    else
        echo "  Patch 2: Channel registration gate — $reg_count match(es)" >&2
        sed -i -E 's/(capability"\};)(if\(![a-zA-Z0-9_$]+\(\)\)return\{action:"skip",kind:"disabled")/\1return\{action:"register"\};\2/g' "$dst"
    fi

    # ── Patch 3: Auto-accept development channels warning ────────────
    local prompt_count
    prompt_count=$(grep -cP '\{return!!\(E8\("userSettings"\)\?\.skipDangerousModePermissionPrompt' "$dst" || true)

    if [ "$prompt_count" -eq 0 ]; then
        echo "  Patch 3: Permission prompt — pattern not found" >&2
    else
        echo "  Patch 3: Permission prompt bypass — $prompt_count match(es)" >&2
        sed -i 's/{return!!(E8("userSettings")?.skipDangerousModePermissionPrompt/{return!0;return!!(E8("userSettings")?.skipDangerousModePermissionPrompt/g' "$dst"
    fi

    # ── Patch 4: Bypass permissions mode gate ────────────────────────
    local bypass_count
    bypass_count=$(grep -cP '\{return [a-zA-Z0-9_$]+\("tengu_disable_bypass_permissions_mode"\)\}' "$dst" || true)

    if [ "$bypass_count" -eq 0 ]; then
        echo "  Patch 4: Bypass permissions gate — pattern not found" >&2
    else
        echo "  Patch 4: Bypass permissions gate — $bypass_count match(es)" >&2
        sed -i -E 's/\{return ([a-zA-Z0-9_$]+)\("tengu_disable_bypass_permissions_mode"\)\}/\{return!1;return \1("tengu_disable_bypass_permissions_mode")\}/g' "$dst"
    fi

    # ── Verify ───────────────────────────────────────────────────────
    local new_size
    new_size=$(stat -c%s "$dst")
    local delta=$((new_size - orig_size))

    if [ "$delta" -lt 5 ]; then
        echo "  WARNING: No patches applied (size delta: ${delta} bytes)" >&2
    else
        echo "  Applied successfully (+${delta} bytes)" >&2
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────

CLI_PATH=$(find_claude_binary)

mkdir -p "$CACHE_DIR"

# Check if re-patching is needed
needs_regen=false

if [ ! -f "$PATCHED_CLI" ]; then
    needs_regen=true
elif [ "$CLI_PATH" -nt "$PATCHED_CLI" ]; then
    needs_regen=true
elif [ -f "$SOURCE_MARKER" ] && [ "$(cat "$SOURCE_MARKER")" != "$CLI_PATH" ]; then
    needs_regen=true
fi

if $needs_regen; then
    apply_patches "$CLI_PATH" "$PATCHED_CLI"
    echo "$CLI_PATH" > "$SOURCE_MARKER"
fi

# ── Auto-detect channel MCP servers ──────────────────────────────────────
#
# Even with the per-server gate patched (patch 2), the outer loop that
# iterates MCP servers for channel registration only fires when
# --channels or --dangerously-load-development-channels is provided.
# We auto-inject the flag for any configured MCP servers so the user
# doesn't have to remember it.

find_channel_servers() {
    # Read MCP server names from the project-scoped config in ~/.claude.json
    # We can't know at this point which servers declare claude/channel capability
    # (that's only known after the MCP handshake), so we include all of them.
    # Servers that don't declare the capability are filtered by the (preserved)
    # capability check in u4$.
    local config="$HOME/.claude.json"
    local cwd
    cwd=$(pwd)

    if [ ! -f "$config" ]; then
        return
    fi

    # Extract server names for the current project directory
    python3 -c "
import json, sys
try:
    with open('$config') as f:
        d = json.load(f)
    for proj_path, proj in d.get('projects', {}).items():
        if proj_path == '$cwd':
            for name in proj.get('mcpServers', {}).keys():
                print(f'server:{name}')
except Exception:
    pass
" 2>/dev/null || true
}

# Build extra flags to inject
EXTRA_ARGS=()

# Always enable bypass permissions (the whole point of using this launcher)
has_skip_perms=false
for arg in "$@"; do
    if [[ "$arg" == "--dangerously-skip-permissions" ]]; then
        has_skip_perms=true
        break
    fi
done
if ! $has_skip_perms; then
    EXTRA_ARGS+=(--dangerously-skip-permissions)
fi

# Auto-inject channel flags for configured MCP servers
already_has_channels=false
for arg in "$@"; do
    if [[ "$arg" == "--dangerously-load-development-channels" ]] || [[ "$arg" == "--channels" ]]; then
        already_has_channels=true
        break
    fi
done

if ! $already_has_channels; then
    CHANNEL_ARGS=()
    while IFS= read -r server; do
        [ -n "$server" ] && CHANNEL_ARGS+=("$server")
    done < <(find_channel_servers)

    if [ ${#CHANNEL_ARGS[@]} -gt 0 ]; then
        EXTRA_ARGS+=(--dangerously-load-development-channels "${CHANNEL_ARGS[@]}")
    fi
fi

# Run the patched JS with bun (npm cli.js, not the compiled binary)
NODE_PATH="$CACHE_DIR/npm/node_modules" exec bun run "$PATCHED_CLI" "${EXTRA_ARGS[@]}" "$@"
