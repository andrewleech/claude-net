#!/usr/bin/env bun
// Hook wrapper for claude-net mirror-session.
//
// Reads a JSON hook payload from stdin, POSTs it to the local mirror-agent
// on 127.0.0.1. Always exits 0 — a failing mirror must never fail the hook.
//
// Budget: 50ms hard timeout. Linux hot-path p99 < 2ms on loopback. macOS
// pays ~5ms per Bun.spawnSync(["ps"]) call inside resolveCcPid() and walks
// up to 4 ancestors, so worst-case macOS p99 is ~20ms before the fetch
// even starts — still well inside the budget but not the same shape.

import * as fs from "node:fs";
import * as os from "node:os";
import * as path from "node:path";

const STATE_DIR = "/tmp/claude-net";
const HOOK_TIMEOUT_MS = 50;

/**
 * Regex used by `resolveCcPid()` to identify the Claude Code binary
 * while walking up the process tree. argv[0] of the ancestor process
 * is tested against this — match on NUL (/proc), whitespace (ps), or
 * end-of-string to stay robust across Linux and macOS.
 *
 * Override with `CLAUDE_NET_CC_BINARY_PATTERN=<regex>` if your install
 * uses a non-default binary name. Invalid pattern falls back to the
 * default — pattern-error never breaks the hook.
 */
const CC_BINARY_PATTERN_SRC =
  process.env.CLAUDE_NET_CC_BINARY_PATTERN ??
  "\\/claude-patched(?:\\x00|\\s|$)";
const CC_BINARY_PATTERN = safeCompileRegex(CC_BINARY_PATTERN_SRC);

function safeCompileRegex(src: string): RegExp {
  try {
    return new RegExp(src);
  } catch {
    return /\/claude-patched(?:\x00|\s|$)/;
  }
}

async function main(): Promise<void> {
  const payload = await readStdin();
  if (!payload) return;

  const port = readPort();
  if (!port) return;

  const enriched = enrichPayload(payload);

  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), HOOK_TIMEOUT_MS);
  try {
    await fetch(`http://127.0.0.1:${port}/hook`, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: enriched,
      signal: controller.signal,
    });
  } catch {
    // Swallow — do not fail the hook.
  } finally {
    clearTimeout(timer);
  }
}

function enrichPayload(raw: string): string {
  // Splice a `_mirror_env` field carrying TMUX / TMUX_PANE into the JSON body
  // so the mirror-agent can discover the tmux target for remote injection.
  // Never throws — if the payload isn't valid JSON, pass it through untouched.
  try {
    const obj = JSON.parse(raw) as Record<string, unknown>;
    if (obj && typeof obj === "object" && !Array.isArray(obj)) {
      obj._mirror_env = {
        TMUX: process.env.TMUX ?? "",
        TMUX_PANE: process.env.TMUX_PANE ?? "",
        CC_PID: resolveCcPid(),
      };
      return JSON.stringify(obj);
    }
  } catch {
    // ignore — pass through
  }
  return raw;
}

function readPort(): number | null {
  try {
    const uid = process.getuid?.() ?? 0;
    const portFile = path.join(STATE_DIR, `mirror-agent-${uid}.port`);
    const content = fs.readFileSync(portFile, "utf8").trim();
    const n = Number.parseInt(content, 10);
    return Number.isFinite(n) && n > 0 ? n : null;
  } catch {
    return null;
  }
}

async function readStdin(): Promise<string | null> {
  try {
    const chunks: Buffer[] = [];
    for await (const chunk of process.stdin) {
      chunks.push(
        typeof chunk === "string"
          ? Buffer.from(chunk)
          : Buffer.from(chunk as Uint8Array),
      );
    }
    const buf = Buffer.concat(chunks);
    if (buf.length === 0) return null;
    return buf.toString("utf8");
  } catch {
    return null;
  }
}

main().catch(() => {
  // Never fail.
});

// Silence unused-import warnings for os (kept for future use).
void os;

/**
 * Walk up the process tree to find Claude Code. `process.ppid` is
 * unreliable for this because Claude Code runs hooks via `sh -c
 * "<command>"` — the direct parent is an ephemeral shell that dies
 * immediately. Walks up to 4 ancestors looking for a cmdline that
 * matches CC_BINARY_PATTERN; falls back to process.ppid if nothing
 * matches.
 */
function resolveCcPid(): number {
  const direct = process.ppid;
  let pid = direct;
  for (let i = 0; i < 4; i++) {
    const info = readProcessInfo(pid);
    if (CC_BINARY_PATTERN.test(info.cmdline)) {
      return pid;
    }
    if (!info.ppid || info.ppid <= 1) break;
    pid = info.ppid;
  }
  return direct;
}

/**
 * Read a process's ppid + cmdline. Linux reads /proc directly (no
 * subprocess cost); macOS/BSD shells out to `ps -o ppid=,command=`
 * (~5 ms per call).
 */
function readProcessInfo(pid: number): { ppid: number; cmdline: string } {
  if (process.platform === "linux") {
    try {
      const cmdline = fs.readFileSync(`/proc/${pid}/cmdline`, "utf8");
      const status = fs.readFileSync(`/proc/${pid}/status`, "utf8");
      const m = status.match(/^PPid:\s*(\d+)/m);
      return {
        ppid: m?.[1] ? Number.parseInt(m[1], 10) : 0,
        cmdline,
      };
    } catch {
      return { ppid: 0, cmdline: "" };
    }
  }
  try {
    const result = Bun.spawnSync({
      cmd: ["ps", "-o", "ppid=,command=", "-p", String(pid)],
      stdout: "pipe",
      stderr: "ignore",
    });
    const out = new TextDecoder().decode(result.stdout).trim();
    const m = out.match(/^\s*(\d+)\s+(.*)$/);
    if (!m?.[1]) return { ppid: 0, cmdline: "" };
    return {
      ppid: Number.parseInt(m[1], 10),
      cmdline: m[2] ?? "",
    };
  } catch {
    return { ppid: 0, cmdline: "" };
  }
}
