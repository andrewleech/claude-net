#!/bin/bash
set -euo pipefail
# Install claude-channels launcher from a local repo clone.
#
# This script is intentionally local-only. For remote install, use the
# hub's /setup endpoint:
#
#   curl -fsSL "$YOUR_HUB/setup" | bash
#
# That path embeds the correct hub URL, downloads binaries from the
# running hub image (respecting whichever branch / tag is deployed),
# and registers the MCP server + hooks. It doesn't require any GitHub
# org / branch to be hardcoded here.

INSTALL_DIR="$HOME/.local/share/claude-channels/bin"
BIN_DIR="$HOME/.local/bin"

mkdir -p "$INSTALL_DIR" "$BIN_DIR"

# Locate the repo clone this script is running from.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-/dev/null}")" 2>/dev/null && pwd || echo "")"

if [ -z "$SCRIPT_DIR" ] || [ ! -f "$SCRIPT_DIR/claude-channels" ]; then
    echo "ERROR: install-channels must be run from a local repo clone." >&2
    echo "For remote install, point at your hub's /setup endpoint:" >&2
    echo "    curl -fsSL \"\$YOUR_HUB/setup\" | bash" >&2
    exit 1
fi

echo "Installing from local clone: $SCRIPT_DIR"
cp "$SCRIPT_DIR/claude-channels" "$INSTALL_DIR/claude-channels"

# claude-channels delegates binary patching to the `cc-patcher` engine
# plus the `claude-net-patcher` provider (patcher-ext/). Both live in a
# single `uv tool` environment: cc-patcher is the tool (it owns the
# `cc-patcher` command claude-channels calls), and claude-net-patcher is
# injected with --with so its channel patches are discovered in the same
# venv. Sibling local clones are preferred when present (dev); otherwise
# they're pulled straight from GitHub.
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PARENT_DIR="$(cd "$REPO_ROOT/.." && pwd)"
CC_PATCHER_GIT="git+https://github.com/andrewleech/cc-patcher"
# claude-net-patcher ships inside the claude-net repo, so it installs
# from that repo's patcher-ext/ subdirectory rather than a repo of its own.
CN_PATCHER_GIT="git+https://github.com/andrewleech/claude-net#subdirectory=patcher-ext"
if command -v uv >/dev/null 2>&1; then
    if [ -d "$PARENT_DIR/cc-patcher" ]; then
        cc_patcher_src="$PARENT_DIR/cc-patcher"
    else
        cc_patcher_src="$CC_PATCHER_GIT"
    fi
    if [ -d "$REPO_ROOT/patcher-ext" ]; then
        cn_patcher_src="$REPO_ROOT/patcher-ext"
    else
        cn_patcher_src="$CN_PATCHER_GIT"
    fi
    echo "Installing cc-patcher + claude-net-patcher as a uv tool…"
    # --reinstall so a re-run picks up updated code even at an unchanged
    # version (uv otherwise serves a cached wheel).
    uv tool install --force --reinstall "$cc_patcher_src" --with "$cn_patcher_src"
else
    echo "WARN: uv not found; skipping cc-patcher / claude-net-patcher install." >&2
    echo "      claude-channels cannot patch the Claude Code binary until you run:" >&2
    echo "          uv tool install $CC_PATCHER_GIT --with $CN_PATCHER_GIT" >&2
fi

if [ -f "$SCRIPT_DIR/claude-net-mirror-push" ]; then
    cp "$SCRIPT_DIR/claude-net-mirror-push" "$INSTALL_DIR/claude-net-mirror-push"
fi
if [ -f "$SCRIPT_DIR/claude-net-mirror-agent" ]; then
    cp "$SCRIPT_DIR/claude-net-mirror-agent" "$INSTALL_DIR/claude-net-mirror-agent"
fi
# Bundle the mirror-agent TS tree so the installed launcher doesn't need
# the source tree alongside.
if [ -f "$SCRIPT_DIR/../src/mirror-agent/agent.ts" ] && command -v bun >/dev/null 2>&1; then
    echo "Bundling mirror-agent..."
    if ! bun build --target=bun \
        "$SCRIPT_DIR/../src/mirror-agent/agent.ts" \
        --outfile "$INSTALL_DIR/mirror-agent.bundle.js" 2>/dev/null; then
        echo "WARN: mirror-agent bundle failed; mirror feature will only work from the repo clone" >&2
    fi
fi

chmod +x "$INSTALL_DIR/claude-channels"
[ -f "$INSTALL_DIR/claude-net-mirror-push" ] && chmod +x "$INSTALL_DIR/claude-net-mirror-push"
[ -f "$INSTALL_DIR/claude-net-mirror-agent" ] && chmod +x "$INSTALL_DIR/claude-net-mirror-agent"

# Remove artifacts from a previous release that no longer exist as
# standalone binaries. claude-net-self-inject was folded into
# `claude-net-mirror-agent inject` as a subcommand — leaving the old
# symlink around would shadow PATH for users.
rm -f "$INSTALL_DIR/claude-net-self-inject" "$BIN_DIR/claude-net-self-inject"

# Symlink to PATH
ln -snf "$INSTALL_DIR/claude-channels" "$BIN_DIR/claude-channels"
[ -f "$INSTALL_DIR/claude-net-mirror-push" ] && ln -snf "$INSTALL_DIR/claude-net-mirror-push" "$BIN_DIR/claude-net-mirror-push"
[ -f "$INSTALL_DIR/claude-net-mirror-agent" ] && ln -snf "$INSTALL_DIR/claude-net-mirror-agent" "$BIN_DIR/claude-net-mirror-agent"

# Retire any running mirror-agent daemon so the next claude-channels launch
# respawns against the just-installed bundle. The launcher's /health probe
# only detects liveness, not version, so a stale daemon would otherwise
# silently keep running the old code.
pkill -f 'claude-net-mirror-agent|mirror-agent\.bundle\.js' 2>/dev/null || true
rm -f /tmp/claude-net/mirror-agent-*.port 2>/dev/null || true

echo ""
echo "Installed claude-channels to $BIN_DIR/claude-channels"
echo ""
echo "Usage: claude-channels [claude args...]"
echo ""

# Check if ~/.local/bin is in PATH
if ! echo "$PATH" | tr ':' '\n' | grep -qx "$BIN_DIR"; then
    echo "NOTE: $BIN_DIR is not in your PATH. Add it:"
    echo "  export PATH=\"$BIN_DIR:\$PATH\""
    echo ""
fi

echo "Run 'claude-channels' instead of 'claude' to enable channels."
