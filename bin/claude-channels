#!/bin/bash
set -euo pipefail
# claude-channels: Drop-in replacement for the `claude` command that enables
# MCP channel support without manual CLI flags or approval prompts.
#
# Patches the Claude Code binary (same-length replacements, original untouched)
# to bypass five channel-related restrictions:
#   1. Feature gate    -- tengu_harbor Statsig flag forced true
#   2. Org policy      -- channelsEnabled check inverted (never blocks)
#   3. Allowlist gate  -- non-dev channel entries skip allowlist check
#   4. Dialog          -- dev channels approval prompt auto-accepted
#   5. Notification    -- suppress stale allowlist warning toast
#
# Auto-detects MCP servers from ~/.claude.json and injects
# --dangerously-load-development-channels for each.
#
# Patched binaries are cached by hash at ~/.local/share/claude-channels/
# and re-patched automatically when Claude Code updates.
#
# Install:
#   curl -fsSL "$YOUR_HUB/setup" | bash   # remote — follows the deployed hub image
#   ./bin/install-channels                # from a local repo clone
#
# Usage:
#   claude-channels              # channels enabled, no prompts
#   claude-channels [any claude args...]

CACHE_DIR="$HOME/.local/share/claude-channels"
PATCHED_LINK="$CACHE_DIR/claude-patched"
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
PATCHER="$(cd "$(dirname "$SELF")" && pwd)/patch-binary.py"

# ── Find Claude Code binary ──────────────────────────────────────────────

find_claude_binary() {
    if [ -n "${CLAUDE_CLI_PATH:-}" ] && [ -f "$CLAUDE_CLI_PATH" ]; then
        echo "$CLAUDE_CLI_PATH"; return 0
    fi

    # Prefer the native binary at known locations (avoids picking up
    # npm/bun global installs which resolve to cli.js instead)
    local candidate resolved
    for candidate in \
        "$HOME/.local/bin/claude" \
        "$HOME/.claude/local/claude" \
        "$HOME/.local/share/claude/versions/"*; do
        if [ -f "$candidate" ]; then
            resolved=$(readlink -f "$candidate" 2>/dev/null || echo "$candidate")
            if [ -f "$resolved" ] && file "$resolved" 2>/dev/null | grep -q "ELF"; then
                echo "$resolved"; return 0
            fi
        fi
    done

    # Fallback: PATH resolution. May find the npm-install launcher
    # `claude.exe` (a tiny wrapper script under .claude/local/node_modules/)
    # which is NOT the Bun-compiled ELF the patcher targets — surface
    # that case with a clear hint instead of letting the patcher fail
    # with "no anchor strings found" once per patch.
    local claude_bin
    claude_bin=$(which claude 2>/dev/null || true)
    if [ -n "$claude_bin" ]; then
        resolved=$(readlink -f "$claude_bin" 2>/dev/null || echo "$claude_bin")
        if [ -f "$resolved" ]; then
            if file "$resolved" 2>/dev/null | grep -q "ELF"; then
                echo "$resolved"; return 0
            fi
            echo "ERROR: \$PATH 'claude' resolves to $resolved, which is not the" >&2
            echo "       Bun-compiled native binary the patcher needs. Likely the" >&2
            echo "       npm-install launcher (claude.exe / cli.js wrapper)." >&2
            echo "       Install the native binary alongside the npm one:" >&2
            echo "           curl -fsSL https://claude.ai/install.sh | bash" >&2
            echo "       That populates ~/.local/share/claude/versions/<v> and" >&2
            echo "       symlinks ~/.local/bin/claude to it — claude-channels" >&2
            echo "       will pick that up automatically." >&2
            return 1
        fi
    fi

    echo "ERROR: Could not find Claude Code binary." >&2
    return 1
}

# ── Auto-detect channel MCP servers ──────────────────────────────────────

find_channel_servers() {
    local config="$HOME/.claude.json"
    [ -f "$config" ] || return

    CLAUDE_JSON="$config" PROJECT_DIR="$(pwd)" python3 -c "
import json, os
seen = set()
try:
    with open(os.environ['CLAUDE_JSON']) as f:
        d = json.load(f)
    cwd = os.environ['PROJECT_DIR']
    for name in d.get('mcpServers', {}).keys():
        if name not in seen:
            seen.add(name)
            print(f'server:{name}')
    for proj_path, proj in d.get('projects', {}).items():
        if proj_path == cwd:
            for name in proj.get('mcpServers', {}).keys():
                if name not in seen:
                    seen.add(name)
                    print(f'server:{name}')
except Exception:
    pass
" 2>/dev/null || true
}

# ── Main ─────────────────────────────────────────────────────────────────

CLI_PATH=$(find_claude_binary)
mkdir -p "$CACHE_DIR"

# Version key from binary hash + patcher hash. The patcher contribution
# matters: when patch-binary.py changes (new patch added, existing patch
# fixed), every cached binary needs re-patching even if the source binary
# is unchanged. Without it, hosts silently keep running the old patch set.
#
# Pipe contents (not file paths) to sha256sum — `sha256sum FILE1 FILE2`
# embeds the paths in its output, which would make the in-repo launcher
# and the installed launcher produce different cache keys even for the
# same byte-identical patcher.
HASH=$(cat "$CLI_PATH" "$PATCHER" | sha256sum | head -c 12)
PATCHED_VERSIONED="$CACHE_DIR/claude-patched-${HASH}"

# Patch if this hash hasn't been patched yet
if [ ! -f "$PATCHED_VERSIONED" ]; then
    patch_exit=0
    python3 "$PATCHER" "$CLI_PATH" "$PATCHED_VERSIONED" || patch_exit=$?

    if [ "$patch_exit" -eq 1 ]; then
        # Fatal error — patched binary is unusable
        rm -f "$PATCHED_VERSIONED"
        echo "Fatal patching error. Falling back to unpatched binary." >&2
        PATCHED_VERSIONED="$CLI_PATH"
    elif [ "$patch_exit" -eq 2 ]; then
        # Partial success — some patches failed.
        # Fall back to the previous patched binary if one exists; otherwise run
        # with partial patches. Don't prompt: this fires on every Claude Code
        # update and the user has already opted in by running claude-channels.
        PREV_PATCHED="$(readlink -f "$PATCHED_LINK" 2>/dev/null || true)"
        if [ -n "$PREV_PATCHED" ] && [ -f "$PREV_PATCHED" ] && [ "$PREV_PATCHED" != "$PATCHED_VERSIONED" ]; then
            echo "[claude-channels] partial patch on new build; using previous patched binary $(basename "$PREV_PATCHED")" >&2
            rm -f "$PATCHED_VERSIONED"
            PATCHED_VERSIONED="$PREV_PATCHED"
        else
            echo "[claude-channels] partial patch; continuing — some channel restrictions may still prompt" >&2
        fi
    fi

    # On macOS, the in-place byte patches invalidate Apple's code
    # signature; AMFI then silently kills the binary at exec ("zsh:
    # killed" with no other output). Ad-hoc re-sign with preserved
    # entitlements so Bun's JIT / dylib loading still works.
    if [ "$PATCHED_VERSIONED" != "$CLI_PATH" ] && [ -f "$PATCHED_VERSIONED" ] \
        && [ "$(uname -s)" = "Darwin" ] \
        && command -v codesign >/dev/null 2>&1; then
        if ! codesign --force \
            --preserve-metadata=entitlements,requirements,flags,runtime \
            --sign - "$PATCHED_VERSIONED" 2>/dev/null; then
            # Some binaries don't have enough metadata to preserve —
            # fall back to a bare ad-hoc sign.
            codesign --force --sign - "$PATCHED_VERSIONED" 2>/dev/null || {
                echo "WARN: codesign failed — macOS AMFI may kill the patched binary at exec." >&2
            }
        fi
    fi

    # Clean up old versioned files (keep current + any fallback target)
    if [ "$PATCHED_VERSIONED" != "$CLI_PATH" ]; then
        find "$CACHE_DIR" -name 'claude-patched-*' \
            ! -name "$(basename "$PATCHED_VERSIONED")" \
            -delete 2>/dev/null || true
    fi
fi

# Symlink to the common name (atomic update, safe even if old version is running)
ln -snf "$PATCHED_VERSIONED" "$PATCHED_LINK"

# Build extra flags
EXTRA_ARGS=()

already_has_channels=false
for arg in "$@"; do
    [[ "$arg" == "--dangerously-load-development-channels" || "$arg" == "--channels" ]] && already_has_channels=true && break
done

if ! $already_has_channels; then
    CHANNEL_ARGS=()
    while IFS= read -r server; do
        [ -n "$server" ] && CHANNEL_ARGS+=("$server")
    done < <(find_channel_servers)
    [ ${#CHANNEL_ARGS[@]} -gt 0 ] && EXTRA_ARGS+=(--dangerously-load-development-channels "${CHANNEL_ARGS[@]}")
fi

# ── Mirror-session daemon (always auto-started) ──────────────────────────
# Starts the mirror-agent daemon in the background (idempotent — the agent
# itself detects an existing instance via its port file). Mirror is always
# on; the `claudeNet.mirror.enabled` setting is no longer consulted.
#
# Hook installation in ~/.claude/settings.json is handled by the hub's
# `/setup` endpoint, not by this launcher. If hooks are missing, mirror
# simply produces no events; the launcher does not mutate settings.json.

mirror_injection_mode() {
    # Echo the configured injection mode ("tmux" | "none" | "patch"), default "tmux".
    local config="$HOME/.claude/settings.json"
    if [ ! -f "$config" ]; then
        echo "tmux"
        return
    fi
    python3 -c "
import json
try:
    with open('$config') as f:
        d = json.load(f)
    v = d.get('claudeNet', {}).get('mirror', {}).get('injection', 'tmux')
    print(v if v in ('tmux', 'none', 'patch') else 'tmux')
except Exception:
    print('tmux')
" 2>/dev/null
}

resolve_hub_url() {
    # Hub URL resolution:
    #   1. CLAUDE_NET_HUB env var (explicit override)
    #   2. env.CLAUDE_NET_HUB on any "claude-net" MCP server in ~/.claude.json
    #      (this is where the plugin already gets its URL, so the mirror-agent
    #      ends up pointing at the same hub without extra configuration)
    #   3. http://localhost:4815 as a last-ditch default — warned loudly,
    #      because a daemon spawned against the wrong hub mirrors nothing
    #      while still answering /health (this went unnoticed for two days).
    # Echoes the URL with trailing slashes stripped so it compares exactly
    # against the daemon's normalized value from /health.
    local hub_url="${CLAUDE_NET_HUB:-}"
    if [ -z "$hub_url" ] && [ -f "$HOME/.claude.json" ]; then
        hub_url=$(CLAUDE_JSON="$HOME/.claude.json" python3 -c "
import json, os
try:
    with open(os.environ['CLAUDE_JSON']) as f:
        d = json.load(f)
    for scope in [d.get('mcpServers', {}),
                  *[p.get('mcpServers', {}) for p in d.get('projects', {}).values()]]:
        cfg = scope.get('claude-net')
        if cfg and cfg.get('env', {}).get('CLAUDE_NET_HUB'):
            print(cfg['env']['CLAUDE_NET_HUB'])
            break
except Exception:
    pass
" 2>/dev/null)
    fi
    if [ -z "$hub_url" ]; then
        echo "[claude-net/mirror] WARNING: hub URL not found in CLAUDE_NET_HUB or ~/.claude.json — falling back to http://localhost:4815" >&2
        hub_url="http://localhost:4815"
    fi
    while [ "${hub_url%/}" != "$hub_url" ]; do hub_url="${hub_url%/}"; done
    echo "$hub_url"
}

_mirror_agent_healthy() {
    # Echoes the live port number on stdout when /health responds 200 AND the
    # daemon's configured hub matches the currently-resolved hub URL; returns
    # non-zero otherwise. Caller uses this to decide whether to skip spawn.
    #
    # The hub comparison matters: a daemon pointed at a stale hub (e.g. the
    # localhost fallback, or a hub URL that changed in ~/.claude.json since
    # spawn) still answers /health, so a liveness-only check keeps it alive
    # forever while every hub call fails. On mismatch the stale daemon is
    # killed here and we return non-zero so the caller's spawn path replaces
    # it with one that re-resolves the config. A /health body without a
    # `hub` field (pre-upgrade daemon) is treated as a mismatch, so old
    # daemons self-heal on the first launch after an upgrade.
    local port_file="$1" port body expected running
    [ -f "$port_file" ] || return 1
    port=$(cat "$port_file" 2>/dev/null || true)
    [ -n "$port" ] || return 1
    body=$(curl -fsS -m 1 "http://127.0.0.1:${port}/health" 2>/dev/null) || return 1

    expected=$(resolve_hub_url)
    # running = "<hub> <pid>" ("-" when the field is absent, pid 0 fallback).
    running=$(HEALTH_BODY="$body" python3 -c "
import json, os
try:
    d = json.loads(os.environ['HEALTH_BODY'])
    hub = str(d.get('hub') or '-').rstrip('/') or '-'
    print(hub, int(d.get('pid') or 0))
except Exception:
    print('- 0')
" 2>/dev/null || echo "- 0")
    local running_hub="${running% *}" daemon_pid="${running#* }"

    if [ "$running_hub" != "$expected" ]; then
        echo "[claude-net/mirror] daemon hub mismatch (running=${running_hub}, config=${expected}) — restarting" >&2
        if [ "$daemon_pid" -gt 0 ] 2>/dev/null; then
            kill "$daemon_pid" 2>/dev/null || true
            # Give it a moment to die so the replacement doesn't race it.
            local i=0
            while [ $i -lt 10 ] && kill -0 "$daemon_pid" 2>/dev/null; do
                sleep 0.1
                i=$((i + 1))
            done
        fi
        rm -f "$port_file" 2>/dev/null || true
        return 1
    fi
    echo "$port"
}

_mirror_agent_spawn() {
    # Caller has already verified no healthy daemon exists. Closes fd 9 on the
    # nohup'd child so it doesn't inherit the spawn lock — otherwise the lock
    # would be held for the lifetime of the daemon and block every subsequent
    # claude-channels start.
    local uid port_file log_file agent_bin hub_url
    uid="$(id -u)"
    port_file="/tmp/claude-net/mirror-agent-${uid}.port"
    log_file="/tmp/claude-net/mirror-agent-${uid}.log"

    agent_bin="$(cd "$(dirname "$SELF")" && pwd)/claude-net-mirror-agent"
    if [ ! -x "$agent_bin" ]; then
        # Try the installed location.
        agent_bin="$HOME/.local/bin/claude-net-mirror-agent"
    fi
    if [ ! -x "$agent_bin" ]; then
        echo "[claude-net/mirror] mirror-agent binary not found; skipping" >&2
        return 1
    fi

    # See resolve_hub_url for the resolution order (env → ~/.claude.json →
    # localhost fallback with a loud warning).
    hub_url=$(resolve_hub_url)
    mkdir -p /tmp/claude-net 2>/dev/null || true
    CLAUDE_NET_HUB="$hub_url" nohup "$agent_bin" >"$log_file" 2>&1 9>&- &
    disown $! 2>/dev/null || true

    # Wait briefly for the port file to appear.
    local i=0
    while [ $i -lt 30 ] && [ ! -f "$port_file" ]; do
        sleep 0.1
        i=$((i + 1))
    done
}

start_mirror_agent() {
    local uid port_file lock_file
    uid="$(id -u)"
    port_file="/tmp/claude-net/mirror-agent-${uid}.port"
    lock_file="/tmp/claude-net/mirror-agent-${uid}.lock"

    mkdir -p /tmp/claude-net 2>/dev/null || true

    # Optimistic fast-path: a healthy daemon already exists, skip the lock.
    if _mirror_agent_healthy "$port_file" >/dev/null; then
        return 0
    fi

    # Slow-path: serialize spawns so concurrent watchdogs don't all spawn
    # duplicate daemons. Without this, /setup's `pkill -f mirror-agent` is
    # followed by every claude-channels watchdog (one per Claude Code
    # session) racing through the existence check at the same moment and
    # producing N daemons.
    #
    # `flock -x -w 10` blocks up to 10 s for an exclusive lock and auto-
    # releases when the subshell's fd 9 closes (so a crash doesn't leave
    # a stale lock). On hosts without flock(1) (rare — bare macOS without
    # util-linux), fall through to an unsynchronised spawn; duplicates
    # are wasteful but not fatal.
    if command -v flock >/dev/null 2>&1; then
        (
            flock -x -w 10 9 || {
                echo "[claude-net/mirror] spawn lock timed out" >&2
                exit 1
            }
            # Re-check now that we hold the lock — a peer may have just spawned.
            if _mirror_agent_healthy "$port_file" >/dev/null; then
                exit 0
            fi
            rm -f "$port_file" 2>/dev/null || true
            _mirror_agent_spawn
        ) 9>"$lock_file"
        return $?
    fi

    rm -f "$port_file" 2>/dev/null || true
    _mirror_agent_spawn
}

start_mirror_agent_watchdog() {
    local uid log_file port_file sentinel
    uid="$(id -u)"
    log_file="/tmp/claude-net/mirror-agent-${uid}.log"
    port_file="/tmp/claude-net/mirror-agent-${uid}.port"
    sentinel="/tmp/claude-net/mirror-agent-${uid}.stopped"

    # Clear any sentinel left by a prior clean shutdown so the incoming agent
    # startup removes it freshly and the watchdog loop below starts clean.
    rm -f "$sentinel" 2>/dev/null || true

    start_mirror_agent || return 1

    # Detached background subshell: polls every 5 s and respawns if the agent
    # is gone. Exits cleanly when the sentinel file appears (written by the
    # agent on idle-shutdown so we don't restart intentional stops).
    # Backoff: consecutive restart failures double the poll delay (5s→10→20→30)
    # to avoid a tight crash-loop filling the log.
    (
        local backoff=5
        while true; do
            sleep "$backoff"
            # Sentinel: agent stopped intentionally — don't restart.
            [ -f "$sentinel" ] && exit 0
            # Port file present + health check passing: all good.
            local port
            port="$(cat "$port_file" 2>/dev/null || true)"
            if [ -n "$port" ] && curl -fsS -m 1 "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
                backoff=5
                continue
            fi
            # Agent is gone without a sentinel — crashed. Restart it.
            rm -f "$port_file" 2>/dev/null || true
            echo "[claude-net/mirror] watchdog: agent down, restarting (backoff=${backoff}s)" >> "$log_file" 2>&1
            if start_mirror_agent >> "$log_file" 2>&1; then
                backoff=5
            else
                backoff=$(( backoff * 2 > 30 ? 30 : backoff * 2 ))
            fi
        done
    ) </dev/null >>"$log_file" 2>&1 &
    disown $! 2>/dev/null || true
}

start_mirror_agent_watchdog || true

# Warn if tmux is needed but missing. Without tmux there's no pane for
# the mirror-agent to send-keys into, so web inject lands as:
#   "inject rejected: session is not running inside tmux (no pane recorded)"
# and silently nothing reaches Claude. Visible warning at startup saves
# the "why isn't my paste landing?" debugging.
if [ "$(mirror_injection_mode)" = "tmux" ] \
    && [ -z "${TMUX:-}" ] \
    && [ -z "${CLAUDE_NET_NO_TMUX_WRAP:-}" ] \
    && ! command -v tmux >/dev/null 2>&1; then
    case "$(uname -s)" in
        Darwin) install_hint="brew install tmux" ;;
        Linux)  install_hint="sudo apt install tmux  # or your package manager" ;;
        *)      install_hint="install tmux via your package manager" ;;
    esac
    echo "[claude-net/mirror] tmux not found — remote inject from the web will be rejected." >&2
    echo "[claude-net/mirror] install tmux to enable: $install_hint" >&2
fi

# Optional: transparent tmux auto-wrap so remote injection has a target.
# Triggered when mirror.injection == "tmux" AND we're not already in tmux
# AND we haven't already wrapped once (guard: CLAUDE_NET_IN_TMUX_WRAP).
if [ -z "${CLAUDE_NET_NO_TMUX_WRAP:-}" ] \
    && [ -z "${CLAUDE_NET_IN_TMUX_WRAP:-}" ] \
    && [ -z "${TMUX:-}" ] \
    && [ "$(mirror_injection_mode)" = "tmux" ] \
    && command -v tmux >/dev/null 2>&1; then
    export CLAUDE_NET_IN_TMUX_WRAP=1
    tmux_session_base="$(basename "$PWD")"

    # A fork/branch/resume is a *second* Claude in the *same directory*, so it
    # collides with the first session's cwd-derived name. If we reattached to the
    # existing session we would (a) silently drop these session-selecting args and
    # (b) mirror one pane into two clients — which reads as the new session
    # "clobbering" the old. So any launch that selects or forks a session always
    # gets its own distinct tmux session instead of reattaching.
    wants_distinct_session=false
    for arg in "$@"; do
        case "$arg" in
            -r|--resume|-c|--continue|--fork-session|--session-id)
                wants_distinct_session=true; break ;;
        esac
    done

    # First unused name in the series base, base-2, base-3, … (matches the
    # plugin's same-dir agent-name collision scheme).
    _free_tmux_session_name() {
        local n=1 name="$tmux_session_base"
        while tmux has-session -t "$name" 2>/dev/null; do
            n=$((n + 1)); name="${tmux_session_base}-${n}"
        done
        echo "$name"
    }

    # True when the session's pane is sitting at an idle shell (claude exited).
    _tmux_pane_is_idle_shell() {
        local cmd
        cmd=$(tmux display-message -t "$1" -p "#{pane_current_command}" 2>/dev/null || true)
        case "$cmd" in bash|sh|zsh|fish|dash|ksh|csh|tcsh) return 0 ;; *) return 1 ;; esac
    }

    if tmux has-session -t "$tmux_session_base" 2>/dev/null \
        && ! $wants_distinct_session \
        && _tmux_pane_is_idle_shell "$tmux_session_base"; then
        # Coming back to this project's session and its claude has exited: cd to
        # the current directory and relaunch in place, then attach. The `&& exec`
        # keeps a single command line (an earlier version omitted the separator,
        # producing `cd DIR SELF ARGS` → "cd: too many arguments") and replaces
        # the pane's shell so its process becomes claude, not a shell parent.
        echo "[claude-net/mirror] reattaching tmux session '$tmux_session_base'" >&2
        relaunch="cd $(printf '%q' "$PWD") && exec"
        for a in "$SELF" "$@"; do relaunch="$relaunch $(printf '%q' "$a")"; done
        tmux send-keys -t "$tmux_session_base" "$relaunch" Enter
        exec tmux attach-session -t "$tmux_session_base"
    elif tmux has-session -t "$tmux_session_base" 2>/dev/null; then
        # Session exists but is busy (or this is an explicit resume/fork): never
        # hijack the running pane. Start a distinct session so the original stays
        # put and reachable and this launch keeps its args.
        tmux_session_name="$(_free_tmux_session_name)"
        echo "[claude-net/mirror] '$tmux_session_base' in use; starting distinct session '$tmux_session_name'" >&2
        exec tmux new-session -s "$tmux_session_name" \
            -e CLAUDE_NET_IN_TMUX_WRAP=1 \
            -- "$SELF" "$@"
    else
        echo "[claude-net/mirror] wrapping in tmux session '$tmux_session_base' (set CLAUDE_NET_NO_TMUX_WRAP=1 to disable)" >&2
        exec tmux new-session -s "$tmux_session_base" \
            -e CLAUDE_NET_IN_TMUX_WRAP=1 \
            -- "$SELF" "$@"
    fi
fi

# Signal to the claude-net plugin that this Claude Code was launched via
# the patched binary, so channels ARE actually loaded. The plugin uses
# this to set `channel_capable: true` on register without needing the
# fragile "LLM call _ack_channel within 60s" ceremony, which agents have
# been observed to ignore as noise.
export CLAUDE_NET_CHANNELS_PATCHED=1
exec "$PATCHED_LINK" "${EXTRA_ARGS[@]}" "$@"
