#!/bin/bash
set -euo pipefail
# claude-channels: Run Claude Code with channel restrictions bypassed.
#
# Binary patches (same-length, native binary safe):
# 1. Channels feature gate (tengu_harbor Statsig flag -> true)
# 2. Org policy channelsEnabled check (inverted so it never blocks)
# 3. Channel allowlist bypass (non-dev entries skip allowlist check)
# 4. Dev channels dialog auto-accept (no approval prompt on startup)
#
# CLI flags auto-injected:
# - --dangerously-load-development-channels server:X (for each configured MCP server)
#
# Usage: claude-channels [claude args...]

CACHE_DIR="$HOME/.local/share/claude-channels"
PATCHED_LINK="$CACHE_DIR/claude-patched"
SOURCE_MARKER="$CACHE_DIR/source_path"
PATCHER="$(cd "$(dirname "$0")" && pwd)/patch-binary.py"

# ── Find Claude Code binary ──────────────────────────────────────────────

find_claude_binary() {
    if [ -n "${CLAUDE_CLI_PATH:-}" ] && [ -f "$CLAUDE_CLI_PATH" ]; then
        echo "$CLAUDE_CLI_PATH"; return 0
    fi

    local claude_bin
    claude_bin=$(which claude 2>/dev/null || true)
    if [ -n "$claude_bin" ]; then
        local resolved
        resolved=$(readlink -f "$claude_bin" 2>/dev/null || echo "$claude_bin")
        if [ -f "$resolved" ]; then
            echo "$resolved"; return 0
        fi
    fi

    echo "ERROR: Could not find Claude Code binary." >&2
    return 1
}

# ── Auto-detect channel MCP servers ──────────────────────────────────────

find_channel_servers() {
    local config="$HOME/.claude.json"
    local cwd
    cwd=$(pwd)
    [ -f "$config" ] || return

    python3 -c "
import json
seen = set()
try:
    with open('$config') as f:
        d = json.load(f)
    # User-wide MCP servers
    for name in d.get('mcpServers', {}).keys():
        if name not in seen:
            seen.add(name)
            print(f'server:{name}')
    # Project-scoped MCP servers for current directory
    for proj_path, proj in d.get('projects', {}).items():
        if proj_path == '$cwd':
            for name in proj.get('mcpServers', {}).keys():
                if name not in seen:
                    seen.add(name)
                    print(f'server:{name}')
except Exception:
    pass
" 2>/dev/null || true
}

# ── Main ─────────────────────────────────────────────────────────────────

CLI_PATH=$(find_claude_binary)
mkdir -p "$CACHE_DIR"

# Determine version and versioned patch path
VERSION=$("$CLI_PATH" --version 2>/dev/null | head -1 | awk '{print $1}')
if [ -z "$VERSION" ]; then
    VERSION="unknown"
fi
PATCHED_VERSIONED="$CACHE_DIR/claude-patched-${VERSION}"

# Patch if this version hasn't been patched yet
if [ ! -f "$PATCHED_VERSIONED" ]; then
    python3 "$PATCHER" "$CLI_PATH" "$PATCHED_VERSIONED"
    echo "$CLI_PATH" > "$SOURCE_MARKER"
fi

# Symlink to the common name (atomic update, safe even if old version is running)
ln -snf "$PATCHED_VERSIONED" "$PATCHED_LINK"

# Build extra flags
EXTRA_ARGS=()

already_has_channels=false
for arg in "$@"; do
    [[ "$arg" == "--dangerously-load-development-channels" || "$arg" == "--channels" ]] && already_has_channels=true && break
done

if ! $already_has_channels; then
    CHANNEL_ARGS=()
    while IFS= read -r server; do
        [ -n "$server" ] && CHANNEL_ARGS+=("$server")
    done < <(find_channel_servers)
    [ ${#CHANNEL_ARGS[@]} -gt 0 ] && EXTRA_ARGS+=(--dangerously-load-development-channels "${CHANNEL_ARGS[@]}")
fi

exec "$PATCHED_LINK" "${EXTRA_ARGS[@]}" "$@"
