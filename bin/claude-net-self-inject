#!/usr/bin/env bun
// Self-inject CLI for claude-net mirror-session.
//
// Posts arbitrary text into the calling Claude Code session's tmux pane
// via the local mirror-agent's /inject endpoint. Useful for an agent
// wanting to queue a slash command for itself (e.g. /mcp reconnect) —
// the text lands at the prompt and Claude Code processes it on the
// next prompt cycle after the current turn finishes.
//
// Usage:
//   claude-net-self-inject "<text>"           # text on argv
//   echo "<text>" | claude-net-self-inject    # text on stdin
//   claude-net-self-inject --sid SID "<text>" # explicit session
//   claude-net-self-inject --pid PID "<text>" # explicit cc pid
//
// Resolution: by default walks the process tree to find the Claude Code
// binary and uses that pid to identify the session. Override with --sid
// or --pid for cross-session injection (e.g. from outside CC).
//
// Exit codes:
//   0  success
//   2  mirror-agent unreachable / not running
//   3  no matching session
//   4  bad arguments
//   5  inject rejected (session closed, not in tmux, etc.)

import * as fs from "node:fs";
import * as path from "node:path";

const STATE_DIR = "/tmp/claude-net";
const FETCH_TIMEOUT_MS = 5_000;

const CC_BINARY_PATTERN_SRC =
  process.env.CLAUDE_NET_CC_BINARY_PATTERN ??
  "\\/claude-patched(?:\\x00|\\s|$)";
const CC_BINARY_PATTERN = safeCompileRegex(CC_BINARY_PATTERN_SRC);

function safeCompileRegex(src: string): RegExp {
  try {
    return new RegExp(src);
  } catch {
    return /\/claude-patched(?:\x00|\s|$)/;
  }
}

interface Args {
  sid: string | null;
  pid: number | null;
  source: string | null;
  text: string | null;
  help: boolean;
}

function parseArgs(argv: string[]): Args | { error: string } {
  const out: Args = {
    sid: null,
    pid: null,
    source: null,
    text: null,
    help: false,
  };
  const positional: string[] = [];
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "-h" || a === "--help") {
      out.help = true;
      continue;
    }
    if (a === "--sid") {
      const v = argv[++i];
      if (!v) return { error: "--sid requires a value" };
      out.sid = v;
      continue;
    }
    if (a === "--pid") {
      const v = argv[++i];
      if (!v) return { error: "--pid requires a value" };
      const n = Number.parseInt(v, 10);
      if (!Number.isFinite(n) || n <= 0) {
        return { error: `--pid must be a positive integer, got '${v}'` };
      }
      out.pid = n;
      continue;
    }
    if (a === "--source") {
      const v = argv[++i];
      if (!v) return { error: "--source requires a value" };
      out.source = v;
      continue;
    }
    if (a === "--") {
      positional.push(...argv.slice(i + 1));
      break;
    }
    if (a?.startsWith("-")) {
      return { error: `unknown flag: ${a}` };
    }
    if (a !== undefined) positional.push(a);
  }
  if (positional.length > 0) out.text = positional.join(" ");
  return out;
}

function usage(): string {
  return [
    "claude-net-self-inject — inject text into the calling Claude Code session",
    "",
    "Usage:",
    "  claude-net-self-inject [--sid SID|--pid PID] [--source NAME] <text>",
    "  echo <text> | claude-net-self-inject [--sid SID|--pid PID] [--source NAME]",
    "",
    "Without --sid/--pid, walks the process tree to find Claude Code and",
    "targets the session bound to that pid.",
  ].join("\n");
}

async function readStdin(): Promise<string> {
  if (process.stdin.isTTY) return "";
  try {
    const chunks: Buffer[] = [];
    for await (const chunk of process.stdin) {
      chunks.push(
        typeof chunk === "string"
          ? Buffer.from(chunk)
          : Buffer.from(chunk as Uint8Array),
      );
    }
    return Buffer.concat(chunks).toString("utf8");
  } catch {
    return "";
  }
}

function readPort(): number | null {
  try {
    const uid = process.getuid?.() ?? 0;
    const portFile = path.join(STATE_DIR, `mirror-agent-${uid}.port`);
    const content = fs.readFileSync(portFile, "utf8").trim();
    const n = Number.parseInt(content, 10);
    return Number.isFinite(n) && n > 0 ? n : null;
  } catch {
    return null;
  }
}

/**
 * Walk up the process tree to find Claude Code's pid. Mirrors the
 * resolution in bin/claude-net-mirror-push so both paths agree on
 * "which CC process owns me".
 */
function resolveCcPid(): number | null {
  let pid = process.ppid;
  for (let i = 0; i < 6; i++) {
    const info = readProcessInfo(pid);
    if (CC_BINARY_PATTERN.test(info.cmdline)) return pid;
    if (!info.ppid || info.ppid <= 1) break;
    pid = info.ppid;
  }
  return null;
}

function readProcessInfo(pid: number): { ppid: number; cmdline: string } {
  if (process.platform === "linux") {
    try {
      const cmdline = fs.readFileSync(`/proc/${pid}/cmdline`, "utf8");
      const status = fs.readFileSync(`/proc/${pid}/status`, "utf8");
      const m = status.match(/^PPid:\s*(\d+)/m);
      return {
        ppid: m?.[1] ? Number.parseInt(m[1], 10) : 0,
        cmdline,
      };
    } catch {
      return { ppid: 0, cmdline: "" };
    }
  }
  try {
    const result = Bun.spawnSync({
      cmd: ["ps", "-o", "ppid=,command=", "-p", String(pid)],
      stdout: "pipe",
      stderr: "ignore",
    });
    const out = new TextDecoder().decode(result.stdout).trim();
    const m = out.match(/^\s*(\d+)\s+(.*)$/);
    if (!m?.[1]) return { ppid: 0, cmdline: "" };
    return {
      ppid: Number.parseInt(m[1], 10),
      cmdline: m[2] ?? "",
    };
  } catch {
    return { ppid: 0, cmdline: "" };
  }
}

async function main(): Promise<number> {
  const argv = process.argv.slice(2);
  const parsed = parseArgs(argv);
  if ("error" in parsed) {
    process.stderr.write(`${parsed.error}\n\n${usage()}\n`);
    return 4;
  }
  if (parsed.help) {
    process.stdout.write(`${usage()}\n`);
    return 0;
  }

  let text = parsed.text;
  if (text === null) text = (await readStdin()).trimEnd();
  if (!text) {
    process.stderr.write(`error: no text to inject\n\n${usage()}\n`);
    return 4;
  }

  const port = readPort();
  if (port === null) {
    process.stderr.write(
      "error: mirror-agent not running (port file missing)\n",
    );
    return 2;
  }

  const body: Record<string, unknown> = { text };
  if (parsed.source) body.source = parsed.source;
  if (parsed.sid) {
    body.sid = parsed.sid;
  } else if (parsed.pid !== null) {
    body.ccPid = parsed.pid;
  } else {
    const pid = resolveCcPid();
    if (pid === null) {
      process.stderr.write(
        "error: could not resolve Claude Code pid from process tree; pass --sid or --pid explicitly\n",
      );
      return 3;
    }
    body.ccPid = pid;
  }

  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
  try {
    const res = await fetch(`http://127.0.0.1:${port}/inject`, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(body),
      signal: controller.signal,
    });
    if (res.ok) return 0;
    const txt = await safeText(res);
    process.stderr.write(`error: ${res.status} ${txt}\n`);
    if (res.status === 404) return 3;
    if (res.status === 409 || res.status === 410) return 5;
    return 5;
  } catch (err) {
    process.stderr.write(`error: ${String(err)}\n`);
    return 2;
  } finally {
    clearTimeout(timer);
  }
}

async function safeText(res: Response): Promise<string> {
  try {
    return (await res.text()).trim();
  } catch {
    return "";
  }
}

const code = await main();
process.exit(code);
